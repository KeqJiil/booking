# Copy this file to .env and fill in real values.

# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
DB_USER=booking_user
DB_PASSWORD=change_me
DB_NAME=booking
DB_URL=postgresql://user:pass@db:5433/booking?schema=public

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis://redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# MinIO
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_URL=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=my-project-bucket

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# Random 40+ character string — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_40_plus_char_string
SALT_ROUNDS=12
ACCESS_TTL=900000
# 15m
REFRESH_TTL=604800000
# 7d
TTL_CACHE=604800
# 7d
TTL_RESET=1800
# 30m
NUMBER_OF_LOGIN_TRIES=5

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_PUBLISH_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WH=whsec_your_main_webhook_signing_secret
STRIPE_WH_THIN=whsec_your_thin_events_webhook_signing_secret

# ---------------------------------------------------------------------------
# Email (Resend)
# ---------------------------------------------------------------------------
RESEND_PASSWORD=your_resend_api_key
RESEND_EMAIL=noreply@yourdomain.com

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# dev | production
NODE_ENV=dev
