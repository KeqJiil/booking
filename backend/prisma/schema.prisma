// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  name  String
  email String @unique
  role  Roles  @default(USER)

  status LiveStatus @default(ALIVE)

  password String

  chatUsers     ChatUser[]
  properties    Property[]
  bookings      Booking[]
  message       Message[]
  reviews       Review[]
  notifications Notification[]

  userSettings UserSettings?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")
}

model UserSettings {
  id String @id @default(uuid())

  theme                  Themes  @default(LIGHT)
  notifications          Boolean @default(true)
  receiveMarketingEmails Boolean @default(false)
  receiveBookingUpdates  Boolean @default(true)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

model Property {
  id String @id @default(uuid())

  name        String
  description String
  price       Decimal    @db.Decimal(10, 2)
  country     String
  city        String
  address     String
  maxGuests   Int
  status      LiveStatus @default(ALIVE)

  images Image[]

  hostId String @map("host_id")
  host   User   @relation(references: [id], fields: [hostId])

  typeId       String?       @map("type_id")
  propertyType PropertyType? @relation(references: [id], fields: [typeId], onDelete: SetNull)

  bookings Booking[]
  reviews  Review[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@index([typeId, price, hostId, country, city, status])
}

model PropertyType {
  id String @id @default(uuid())

  name String @unique

  properties Property[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@map("property_type")
}

model Image {
  id String @id @default(uuid())

  url        String
  propertyId String   @map("property_id")
  property   Property @relation(references: [id], fields: [propertyId], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
}

model Booking {
  id String @id @default(uuid())

  amountDue     Decimal @map("amount_due") @db.Decimal(10, 2)
  days          Int
  priceAtMoment Decimal @map("price_at_moment") @db.Decimal(10, 2)

  status Status

  userId String @map("user_id")
  user   User   @relation(references: [id], fields: [userId])

  propertyId String   @map("property_id")
  property   Property @relation(references: [id], fields: [propertyId])

  review Review?
  chats  Chat[]

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@index([startDate, endDate])
}

model Review {
  id String @id @default(uuid())

  rating      Int
  description String

  reviewerId String @map("reviewer_id")
  reviewer   User   @relation(references: [id], fields: [reviewerId])

  bookingId String  @unique @map("booking_id")
  booking   Booking @relation(references: [id], fields: [bookingId])

  propertyId String   @map("property_id")
  property   Property @relation(references: [id], fields: [propertyId])

  createdAt DateTime @default(now())

  @@unique([reviewerId, bookingId, propertyId])
  @@index([propertyId])
}

model Chat {
  id String @id @default(uuid())

  name String

  chatUsers ChatUser[]
  messages  Message[]

  status LiveStatus

  bookingId String?  @map("booking_id")
  booking   Booking? @relation(references: [id], fields: [bookingId], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")
}

model Message {
  id String @id @default(uuid())

  text String

  chat   Chat   @relation(fields: [chatId], references: [id])
  chatId String @map("chat_id")

  userId String @map("user_id")
  user   User   @relation(references: [id], fields: [userId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")
}

model ChatUser {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  chatId String @map("chat_id")
  chat   Chat   @relation(fields: [chatId], references: [id])
}

model Notification {
  id String @id @default(uuid())

  type NotificationTypes
  text String

  payload Json?

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  isSeen Boolean @default(false) @map("is_seen")

  createdAt DateTime @default(now()) @map("created_at")
}

enum Roles {
  USER
  HOST
  ADMIN
}

enum Status {
  PENDING
  PAID

  CANCELLED
  EXPIRED
  REJECTED

  CONFIRMED
  COMPLETED
}

enum Themes {
  DARK
  LIGHT
}

enum LiveStatus {
  DELETED
  ALIVE
}

enum NotificationTypes {
  BOOKING_REQUEST
  BOOKING_CONFIRMED
  BOOKING_REJECTED
  BOOKING_CANCELLED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  NEW_MESSAGE
  REVIEW_RECEIVED
  SYSTEM_INFO
  SYSTEM_SECURITY
}
