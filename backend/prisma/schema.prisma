// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  name             String
  role             Roles   @default(USER)
  paymentAccountId String? @map("payment_account_id")
  avatarUrl        String? @map("avatar_url")

  status LiveStatus @default(NOT_CONFIRMED)

  authCredentials AuthCredential?
  chatUsers       ChatUser[]
  properties      Property[]
  bookings        Booking[]
  message         Message[]
  reviews         Review[]
  notifications   Notification[]
  idempotencyKeys IdempotencyKey[]
  payments        Payment[]

  userSettings UserSettings?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")
}

model AuthCredential {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  passwordHash String @map("password_hash")
  email        String @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")
}

model UserSettings {
  id String @id @default(uuid())

  theme                  Themes  @default(LIGHT)
  notifications          Boolean @default(true)
  receiveMarketingEmails Boolean @default(false)
  receiveBookingUpdates  Boolean @default(true)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

model Property {
  id String @id @default(uuid())

  name        String
  description String
  price       Decimal    @db.Decimal(10, 2)
  country     String
  city        String
  address     String
  maxGuests   Int
  status      LiveStatus @default(ALIVE)

  images Image[]

  hostId String @map("host_id")
  host   User   @relation(references: [id], fields: [hostId])

  typeId       String?       @map("type_id")
  propertyType PropertyType? @relation(references: [id], fields: [typeId], onDelete: SetNull)

  bookings Booking[]
  reviews  Review[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@index([typeId, price, hostId, country, city, status])
}

model PropertyType {
  id String @id @default(uuid())

  name String @unique

  properties Property[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@map("property_type")
}

model Image {
  id String @id @default(uuid())

  url        String
  propertyId String   @map("property_id")
  property   Property @relation(references: [id], fields: [propertyId], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
}

model Booking {
  id String @id @default(uuid())

  amountDue     Decimal @map("amount_due") @db.Decimal(10, 2)
  days          Int
  priceAtMoment Decimal @map("price_at_moment") @db.Decimal(10, 2)

  status Status

  userId String @map("user_id")
  user   User   @relation(references: [id], fields: [userId])

  propertyId String   @map("property_id")
  property   Property @relation(references: [id], fields: [propertyId])

  review Review?
  chats  Chat[]

  payment Payment?

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")

  @@index([startDate, endDate])
}

model Review {
  id String @id @default(uuid())

  rating      Int
  description String

  reviewerId String @map("reviewer_id")
  reviewer   User   @relation(references: [id], fields: [reviewerId])

  bookingId String  @unique @map("booking_id")
  booking   Booking @relation(references: [id], fields: [bookingId])

  propertyId String   @map("property_id")
  property   Property @relation(references: [id], fields: [propertyId])

  createdAt DateTime @default(now())

  @@unique([reviewerId, bookingId, propertyId])
  @@index([propertyId])
}

model Chat {
  id String @id @default(uuid())

  name String

  chatUsers ChatUser[]
  messages  Message[]

  status LiveStatusChat

  bookingId String?  @map("booking_id")
  booking   Booking? @relation(references: [id], fields: [bookingId], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")
}

model Message {
  id String @id @default(uuid())

  text String

  chat   Chat   @relation(fields: [chatId], references: [id])
  chatId String @map("chat_id")

  userId String @map("user_id")
  user   User   @relation(references: [id], fields: [userId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")
}

model ChatUser {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  chatId String @map("chat_id")
  chat   Chat   @relation(fields: [chatId], references: [id])
}

model Notification {
  id String @id @default(uuid())

  type NotificationTypes
  text String

  payload Json?

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  isSeen Boolean @default(false) @map("is_seen")

  createdAt DateTime @default(now()) @map("created_at")
}

model IdempotencyKey {
  id String @id @default(uuid())

  key String

  statusCode Int?  @map("status_code")
  response   Json?

  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  expiredAt  DateTime @map("expired_at")
  createdAt  DateTime @default(now()) @map("created_at")
  propertyId String?

  @@unique([key, userId])
  @@index([userId])
  @@map("idempotency_key")
}

model Payment {
  id String @id @default(uuid())

  userId String @map("user_id")
  user   User   @relation(references: [id], fields: [userId])

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  status   PaymentStatuses @default(PENDING)
  amount   Int
  currency Currency        @default(usd)

  providerPaymentId String?

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")
}

model Outbox {
  id String @id @default(uuid())

  itemId  String
  type    OutboxEvents
  payload Json
  status  OutboxStatuses @default(PENDING)

  retries Int @default(0)

  processingAt DateTime? @map("processing_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
}

enum Roles {
  USER
  HOST
  ADMIN
}

enum Status {
  PENDING
  PAID

  CANCELLED
  EXPIRED
  REJECTED

  CONFIRMED
  COMPLETED
}

enum Themes {
  DARK
  LIGHT
}

enum LiveStatus {
  DELETED
  ALIVE
  NOT_CONFIRMED
}

enum NotificationTypes {
  forgot_password
  accound_need_confirmation
  account_created
  password_changed
  new_role_received
  property_created
  property_changed
  property_deleted
  property_images_updated
  property_images_added
  property_images_deleted
  able_to_leave_review
  new_review_received
  new_review_created
  review_edited
  booking_created
  booking_paid
  booking_expired
  booking_rejected
  booking_cancelled
  booking_confirmed
  booking_completed
  chat_created
  billing_refund
}

enum PaymentStatuses {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum OutboxEvents {
  REFUND_REQUEST
}

enum OutboxStatuses {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum Currency {
  usd
}

enum LiveStatusChat {
  DELETED
  ALIVE
}
